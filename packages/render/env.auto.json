{
  "consts": {
    "TOGGLES": [
      {
        "key": "isOnlinePaymentEnabled",
        "label": "Online payment",
        "help": "Allow customers to pay online (UPI / card) in this city."
      },
      {
        "key": "isWhatsappNotificationEnabled",
        "label": "WhatsApp notifications",
        "help": "Send order updates to customers over WhatsApp."
      },
      {
        "key": "isCancelableEnabled",
        "label": "Order cancellable",
        "help": "Allow customers to cancel orders in this city."
      },
      {
        "key": "blockOrderCreationWhenNoPartnerAvailable",
        "label": "Block orders when no partner available",
        "help": "Stop new orders when no delivery partner is available."
      },
      {
        "key": "blockOnlinePaymentWhenNoPartnerAvailable",
        "label": "Block online payment when no partner available",
        "help": "Disable online payment when no delivery partner is available."
      }
    ]
  },
  "keyframes": [
    {
      "id": "K1",
      "label": "loading"
    },
    {
      "id": "K2",
      "label": "!(loading) && !extraDetails"
    },
    {
      "id": "K3",
      "label": "!(loading) && !(!extraDetails) && canEdit"
    },
    {
      "id": "K4",
      "label": "!(loading) && !(!extraDetails) && !canEdit"
    }
  ],
  "envs": {
    "K1": {
      "saving": false,
      "canEdit": true,
      "extraDetails": null,
      "toggles": {},
      "qrCode": "",
      "loading": true
    },
    "K2": {
      "saving": false,
      "canEdit": true,
      "extraDetails": null,
      "toggles": {},
      "qrCode": "",
      "loading": false
    },
    "K3": {
      "saving": false,
      "canEdit": true,
      "extraDetails": {
        "payment": {
          "qrCode": "https://cdn.belivmart.example/qr/city_123.png"
        },
        "isOnlinePaymentEnabled": true,
        "isWhatsappNotificationEnabled": false,
        "isCancelableEnabled": true,
        "blockOrderCreationWhenNoPartnerAvailable": false,
        "blockOnlinePaymentWhenNoPartnerAvailable": true
      },
      "toggles": {
        "isOnlinePaymentEnabled": true,
        "isWhatsappNotificationEnabled": false,
        "isCancelableEnabled": true,
        "blockOrderCreationWhenNoPartnerAvailable": false,
        "blockOnlinePaymentWhenNoPartnerAvailable": true
      },
      "qrCode": "https://cdn.belivmart.example/qr/city_123.png",
      "loading": false
    },
    "K4": {
      "saving": false,
      "canEdit": false,
      "extraDetails": {
        "payment": {
          "qrCode": "https://cdn.belivmart.example/qr/city_123.png"
        },
        "isOnlinePaymentEnabled": true,
        "isWhatsappNotificationEnabled": false,
        "isCancelableEnabled": true,
        "blockOrderCreationWhenNoPartnerAvailable": false,
        "blockOnlinePaymentWhenNoPartnerAvailable": true
      },
      "toggles": {
        "isOnlinePaymentEnabled": true,
        "isWhatsappNotificationEnabled": false,
        "isCancelableEnabled": true,
        "blockOrderCreationWhenNoPartnerAvailable": false,
        "blockOnlinePaymentWhenNoPartnerAvailable": true
      },
      "qrCode": "https://cdn.belivmart.example/qr/city_123.png",
      "loading": false
    }
