{
  "name": "contextify",
  "displayName": "Contextify",
  "version": "0.3.0",
  "description": "Persistent context engine for Claude Code: your project gets a permanent understanding layer (screenshots → structured markdown, code → live Software Knowledge Graph) so Claude queries instead of re-discovering. React/Next.js + Flutter. Impact analysis, architecture score, temporal diffs — all local, code never leaves your machine.",
  "author": {
    "name": "PixelContextify"
  },
  "homepage": "https://github.com/Sam123336/PixelContextify",
  "repository": "https://github.com/Sam123336/PixelContextify",
  "license": "MIT",
  "keywords": ["mcp", "screenshot", "vision", "ui", "context-compression", "knowledge-graph", "impact-analysis", "nextjs"],
  "mcpServers": {
    "contextify": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bundle/index.cjs"],
      "env": {
        "CONTEXTIFY_BACKEND_URL": "${CONTEXTIFY_BACKEND_URL:-https://contextify-backend-mdrs.onrender.com}",
        "CONTEXTIFY_LLM_PROVIDER": "${CONTEXTIFY_LLM_PROVIDER:-}",
        "CONTEXTIFY_LLM_API_KEY": "${CONTEXTIFY_LLM_API_KEY:-}",
        "CONTEXTIFY_LLM_MODEL": "${CONTEXTIFY_LLM_MODEL:-}",
        "CONTEXTIFY_LLM_BASE_URL": "${CONTEXTIFY_LLM_BASE_URL:-}"
      }
    }
  }
}
