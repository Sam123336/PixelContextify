{
  "name": "contextify",
  "displayName": "Contextify",
  "version": "0.2.1",
  "description": "Turn UI screenshots into structured developer markdown — ~95% fewer vision tokens for Claude Code. Bring your own LLM key (Gemini / OpenAI / Anthropic / any OpenAI-compatible endpoint).",
  "author": {
    "name": "PixelContextify"
  },
  "homepage": "https://github.com/Sam123336/PixelContextify",
  "repository": "https://github.com/Sam123336/PixelContextify",
  "license": "MIT",
  "keywords": ["mcp", "screenshot", "vision", "ui", "context-compression"],
  "mcpServers": {
    "contextify": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bundle/index.cjs"],
      "env": {
        "CONTEXTIFY_BACKEND_URL": "${CONTEXTIFY_BACKEND_URL:-http://localhost:3000}",
        "CONTEXTIFY_LLM_PROVIDER": "${CONTEXTIFY_LLM_PROVIDER:-}",
        "CONTEXTIFY_LLM_API_KEY": "${CONTEXTIFY_LLM_API_KEY:-}",
        "CONTEXTIFY_LLM_MODEL": "${CONTEXTIFY_LLM_MODEL:-}",
        "CONTEXTIFY_LLM_BASE_URL": "${CONTEXTIFY_LLM_BASE_URL:-}"
      }
    }
  }
}
