{
  "name": "@contextifly/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Contextifly MCP server — exposes screenshot-to-markdown tools to Claude Code over stdio",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "contextifly-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle:plugin": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=bundle/index.cjs",
    "start": "node dist/index.js",
    "test": "echo \"no tests\" && exit 0",
    "lint": "echo \"no lint\" && exit 0"
  },
  "dependencies": {
    "@contextifly/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.3"
  }
}
