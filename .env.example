NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://contextify:contextify@localhost:5432/contextify
REDIS_URL=redis://localhost:6379

# Server-default LLM used when a request does not bring its own key.
# LLM_PROVIDER: gemini | openai | anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=
# Leave blank to use the provider's default model (gemini-2.0-flash,
# gpt-4o, claude-3-5-sonnet-latest).
LLM_MODEL=

# Deprecated aliases — still honoured when LLM_* are unset.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
QUEUE_CONCURRENCY=4
